# harness.yaml — project-local config (non-secret tunables only)
# Copy to harness.yaml in your project root and edit as needed.
# NEVER put secrets here. DATABASE_URL, GITHUB_TOKEN, OPENAI_API_KEY come from ENV.

project:
  name: sample

repositories:
  - type: github
    name: dotnet/runtime
    # Per-repo scope overrides the project default (D-A3).
    # mode: all | last_n | since_date | period
    # value: omit for "all"; int for last_n; ISO date for since_date; "90d" for period.
    # scope: { mode: last_n, value: 200 }

ingest:
  # Default scope for repos that omit per-repo scope (D-A3).
  # Replaces the old default_last_n key. Supported modes: all, last_n, since_date, period.
  # default_scope: { mode: last_n, value: 100 }
  # Legacy key still supported for back-compat:
  default_last_n: 100
  # Bot stop-list: authors unconditionally excluded (in addition to [bot] suffix).
  # Useful for automation under human-looking accounts (e.g. internal-sync bots).
  # stop_list: [dependabot, renovate]
  # Automation-title filter: case-insensitive regexes over the PR title;
  # matching PRs are excluded before any per-PR API call. Catches recurring
  # automation whose author is not bot-suffixed.
  # title_stop_patterns:
  #   - 'update dependencies from'
  #   - 'merging internal commits'
  #   - '\[automated\]'
  # Giant-PR thresholds (strictly-greater comparisons):
  # max_files: 100     # exclude PRs touching more than this many files
  # max_lines: 5000    # exclude PRs with more than this many added+deleted lines
  # Rate-limit floor: pause ingest when remaining API calls < this value.
  # rate_limit_floor: 100
  # Optional inter-fetch delay in seconds (0.0 = off).
  # inter_fetch_delay: 0.0

embed:
  model: text-embedding-3-small
  version: v1
  problem_limit_tokens: 1500
  diff_limit_tokens: 6000
  # Optional: route embeddings through any OpenAI-compatible endpoint.
  # Leave unset for OpenAI (api.openai.com). For OpenRouter, uncomment both
  # lines and set OPENAI_API_KEY to your OpenRouter key (sk-or-...).
  # The model MUST return 1536-dim vectors to match the skills schema.
  # base_url: https://openrouter.ai/api/v1
  # model: openai/text-embedding-3-small

search:
  top_n: 5
  score_threshold: 0.40
  problem_weight: 0.6
  solution_weight: 0.4
  oversample_factor: 5

mcp:
  # Maximum characters for diff excerpts returned by search_prs_v1 (D-04).
  # Approx. 500 tokens at typical code density. Increase if agents need more diff context.
  output_diff_limit: 2000
  # Bind address for --transport network. Use "0.0.0.0" to expose on a shared interface
  # (requires explicit opt-in — D-07). Default 127.0.0.1 keeps the server local-only.
  host: "127.0.0.1"
  # Bind port for --transport network.
  port: 8000
  # FastMCP log level. Use "INFO" or "DEBUG" for troubleshooting.
  log_level: "WARNING"
