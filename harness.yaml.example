# harness.yaml — project-local config (non-secret tunables only)
# Copy to harness.yaml in your project root and edit as needed.
# NEVER put secrets here. DATABASE_URL, GITHUB_TOKEN, OPENAI_API_KEY come from ENV.

project:
  name: sample

repositories:
  - type: github
    name: dotnet/runtime

ingest:
  default_last_n: 100

embed:
  model: text-embedding-3-small
  version: v1
  problem_limit_tokens: 1500
  diff_limit_tokens: 6000
  # Optional: route embeddings through any OpenAI-compatible endpoint.
  # Leave unset for OpenAI (api.openai.com). For OpenRouter, uncomment both
  # lines and set OPENAI_API_KEY to your OpenRouter key (sk-or-...).
  # The model MUST return 1536-dim vectors to match the skills schema.
  # base_url: https://openrouter.ai/api/v1
  # model: openai/text-embedding-3-small

search:
  top_n: 5
  score_threshold: 0.40
  problem_weight: 0.6
  solution_weight: 0.4
  oversample_factor: 5

mcp:
  # Maximum characters for diff excerpts returned by search_prs_v1 (D-04).
  # Approx. 500 tokens at typical code density. Increase if agents need more diff context.
  output_diff_limit: 2000
  # Bind address for --transport network. Use "0.0.0.0" to expose on a shared interface
  # (requires explicit opt-in — D-07). Default 127.0.0.1 keeps the server local-only.
  host: "127.0.0.1"
  # Bind port for --transport network.
  port: 8000
  # FastMCP log level. Use "INFO" or "DEBUG" for troubleshooting.
  log_level: "WARNING"
