# GSD planning docs kept local-only
.planning/

# Secrets — never commit real values
.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/

# Build artifacts (produced by `python -m build`; published from CI, never committed)
dist/
build/

# Project-local config: real per-user tunables stay local (copy from
# senrah.yaml.example). Keeps "temporary" tokens from ever being tracked.
senrah.yaml

# Local tooling binaries (gitleaks etc.) — fetched per machine, never committed
tools/

# Runtime artifacts: opt-in search log (may contain query text) and the
# MCP heartbeat/status file
senrah-search.log
senrah-mcp-status.json

# Eval cluster: cached GitHub commit-message responses (public PR data, not secrets;
# gitignored because they are generated/runtime output, not source artifacts).
eval/cluster/.commitcache/
