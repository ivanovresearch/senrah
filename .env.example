# Senrah — ENV secrets (copy to .env for local dev, never commit .env)
# All three values are required to run senrah commands.

# PostgreSQL connection string (contains password → ENV only, never in senrah.yaml)
DATABASE_URL=postgresql://user:password@localhost:5432/harness

# GitHub Personal Access Token
# Fine-grained PAT preferred: read-only access to Pull Requests and Issues
# Classic PAT scope: public_repo (read-only for public repos)
GITHUB_TOKEN=ghp_placeholder_replace_with_real_token

# OpenAI API key — embeddings-only scope (text-embedding-3-small)
# This key is also used for OpenAI-compatible providers. For OpenRouter, set
# this to your OpenRouter key (sk-or-...) and set embed.base_url in senrah.yaml
# to https://openrouter.ai/api/v1 (with model: openai/text-embedding-3-small).
OPENAI_API_KEY=sk-placeholder_replace_with_real_key

# Optional: search query logging (OPS-05). DISABLED by default — nothing is
# written anywhere unless SEARCH_LOG is set to true.
# PRIVACY NOTE: when enabled, the FULL QUERY TEXT is appended to the log
# file. On private repositories query text can reveal proprietary code or
# internal problem descriptions — enable only for retrieval debugging and
# treat the log file as sensitive.
# SEARCH_LOG=true
# SEARCH_LOG_PATH=senrah-search.log
