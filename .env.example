# Harness — ENV secrets (copy to .env for local dev, never commit .env)
# All three values are required to run harness commands.

# PostgreSQL connection string (contains password → ENV only, never in harness.yaml)
DATABASE_URL=postgresql://user:password@localhost:5432/harness

# GitHub Personal Access Token
# Fine-grained PAT preferred: read-only access to Pull Requests and Issues
# Classic PAT scope: public_repo (read-only for public repos)
GITHUB_TOKEN=ghp_placeholder_replace_with_real_token

# OpenAI API key — embeddings-only scope (text-embedding-3-small)
OPENAI_API_KEY=sk-placeholder_replace_with_real_key
