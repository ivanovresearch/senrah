+
+    #region 38140
+
+    [Theory, MemberData(nameof(IsAsyncData))]
+    public virtual async Task GroupBy_Select_with_FirstOrDefault_followed_by_projecting_entity_properties(bool async)
+    {
+        var contextFactory = await InitializeNonSharedTest<Context38140>(
+            seed: async context =>
+            {
+                var report = new Context38140.Report { Id = 1, Name = "Report 1" };
+                context.Add(report);
+                context.AddRange(
+                    new Context38140.ReportItem { Id = 1, Name = "Item 1", ReportId = 1, Time = 10 },
+                    new Context38140.ReportItem { Id = 2, Name = "Item 2", ReportId = 1, Time = 20 },
+                    new Context38140.ReportItem { Id = 3, Name = "Item 3", ReportId = 1, Time = 30 });
+                await context.SaveChangesAsync();
+            });
+
+        using var context = contextFactory.CreateDbContext();
+
+        var query = context.Set<Context38140.ReportItem>()
+            .GroupBy(e => e.Report.Name)
+            .Select(g => new
+            {
+                g.Key,
+                MaxTime = g.OrderByDescending(i => i.Time).FirstOrDefault()
+            })
+            .Where(i => i.MaxTime != null)
+            .Select(i => new
+            {
+                Name = i.Key,
+                TimeName = i.MaxTime.Name,
+                i.MaxTime.Time
+            });
+
+        var result = async
+            ? await query.ToListAsync()
+            : query.ToList();
+
+        Assert.Equal(1, result.Count);
+        Assert.Equal("Report 1", result[0].Name);
+        Assert.Equal("Item 3", result[0].TimeName);
+        Assert.Equal(30, result[0].Time);
+    }
+
+    protected class Context38140(DbContextOptions options) : DbContext(options)
+    {
+        protected override void OnModelCreating(ModelBuilder modelBuilder)
+        {
+        }
+
+        public class Report
+        {
+            public int Id { get; set; }
+            public required string Name { get; set; }
+            public List<ReportItem> Items { get; set; } = [];
+        }
+
+        public class ReportItem
+        {
+            public int Id { get; set; }
+            public required string Name { get; set; }
+            public int ReportId { get; set; }
+            public Report Report { get; set; }
+            public int Time { get; set; }
+        }
+    }
+
+    #endregion
