+        SqlExpression TranslateSign(SqlExpression arg)
+        {
+            var typeMapping = ExpressionExtensions.InferTypeMapping(arg);
+            var signExpr = sqlExpressionFactory.Function(
+                "SIGN",
+                [sqlExpressionFactory.ApplyTypeMapping(arg, typeMapping)],
+                nullable: true,
+                argumentsPropagateNullability: Statics.TrueArrays[1],
+                arg.Type,
+                typeMapping);
+
+            // T-SQL SIGN returns the same data type as its argument, but Math.Sign always returns int.
+            // For non-integer argument types we must cast the result to int so the materializer reads
+            // the correct type from the data reader.
+            return arg.Type == typeof(int)
+                ? (SqlExpression)sqlExpressionFactory.ApplyTypeMapping(signExpr, typeMapping)
+                : sqlExpressionFactory.Convert(signExpr, typeof(int));
+        }
+
