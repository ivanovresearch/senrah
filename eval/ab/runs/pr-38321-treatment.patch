+    #region 38321
+
+    [Fact]
+    public virtual async Task Where_on_json_owned_many_mapped_to_view()
+    {
+        var contextFactory = await InitializeNonSharedTest<DbContext>(
+            onModelCreating: modelBuilder =>
+            {
+                modelBuilder.Entity<PersonOrdersView38321>(entity =>
+                {
+                    entity.HasNoKey();
+                    entity.ToView("PersonOrdersView38321");
+                    entity.OwnsMany(e => e.OrderIds, builder => builder.ToJson().HasColumnType(JsonColumnType));
+                });
+            },
+            seed: async ctx =>
+            {
+                await ctx.Database.ExecuteSqlAsync(
+                    $$"""
+CREATE TABLE [Persons38321] (
+    [PersonId] int NOT NULL PRIMARY KEY,
+    [OrderIds] nvarchar(max) NULL
+)
+""");
+
+                await ctx.Database.ExecuteSqlAsync(
+                    $$"""
+CREATE VIEW [PersonOrdersView38321] AS
+SELECT [PersonId], [OrderIds] FROM [Persons38321]
+""");
+
+                await ctx.Database.ExecuteSqlAsync(
+                    $$"""
+INSERT INTO [Persons38321] ([PersonId], [OrderIds])
+VALUES (1, N'[{"Value":10},{"Value":20}]'),
+       (2, N'[{"Value":30}]')
+""");
+            });
+
+        await using var context = contextFactory.CreateDbContext();
+
+        var result = await context.Set<PersonOrdersView38321>()
+            .Where(po => po.OrderIds.Any(oId => oId.Value == 10))
+            .ToListAsync();
+
+        Assert.Single(result);
+        Assert.Equal(1, result[0].PersonId);
+    }
+
+    private class PersonOrdersView38321
+    {
+        public int PersonId { get; set; }
+        public List<OrderId38321> OrderIds { get; set; } = [];
+    }
+
+    private class OrderId38321
+    {
+        public int Value { get; set; }
+    }
+
+    #endregion
