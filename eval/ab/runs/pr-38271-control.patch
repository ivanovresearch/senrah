+    /// <summary>
+    ///     Returns <see langword="true" /> if a <see cref="CreateIndexOperation" /> that targets the same
+    ///     index (name, table, schema) as <paramref name="operation" /> appears after it in the current
+    ///     batch, and that operation is eligible for <c>DROP_EXISTING = ON</c> (i.e. not a full-text,
+    ///     vector, or JSON index).
+    /// </summary>
+    private bool HasFollowingCreateIndexOperation(DropIndexOperation operation)
+        => _operations is not null
+            && _operations
+                .SkipWhile(o => o != operation)
+                .Skip(1)
+                .OfType<CreateIndexOperation>()
+                .Any(o => o.Name == operation.Name
+                    && o.Table == operation.Table
+                    && o.Schema == operation.Schema
+                    && o[SqlServerAnnotationNames.FullTextIndex] is null
+                    && o[SqlServerAnnotationNames.VectorIndexMetric] is null
+                    && o[RelationalAnnotationNames.JsonIndex] is null);
+
+    /// <summary>
+    ///     Returns <see langword="true" /> if a <see cref="DropIndexOperation" /> that targets the same
+    ///     index (name, table, schema) as <paramref name="operation" /> appears before it in the current
+    ///     batch, indicating the drop was suppressed and <c>DROP_EXISTING = ON</c> should be used.
+    /// </summary>
+    private bool HasPrecedingDropIndexOperation(CreateIndexOperation operation)
+        => _operations is not null
+            && _operations
+                .TakeWhile(o => o != operation)
+                .OfType<DropIndexOperation>()
+                .Any(o => o.Name == operation.Name
+                    && o.Table == operation.Table
+                    && o.Schema == operation.Schema
+                    && o[SqlServerAnnotationNames.FullTextIndex] is null);
+
