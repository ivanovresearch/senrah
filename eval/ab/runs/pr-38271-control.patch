+    [Fact]
+    public void DropIndex_followed_by_CreateIndex_uses_drop_existing()
+    {
+        Generate(
+            new DropIndexOperation
+            {
+                Name = "IX_People_Name",
+                Table = "People",
+                Schema = "dbo"
+            },
+            new CreateIndexOperation
+            {
+                Name = "IX_People_Name",
+                Table = "People",
+                Schema = "dbo",
+                Columns = ["FirstName", "LastName"],
+                [SqlServerAnnotationNames.FillFactor] = 80
+            });
+
+        AssertSql(
+            """
+CREATE INDEX [IX_People_Name] ON [dbo].[People] ([FirstName], [LastName]) WITH (FILLFACTOR = 80, DROP_EXISTING = ON);
+""");
+    }
+
+    [Fact]
+    public void DropIndex_followed_by_CreateIndex_different_name_does_not_use_drop_existing()
+    {
