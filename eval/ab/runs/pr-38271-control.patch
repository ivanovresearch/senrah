+                Name = "IX_People_Name",
+                Table = "People",
+                Schema = "dbo"
+            },
+            new CreateIndexOperation
+            {
+                Name = "IX_People_OtherName",
+                Table = "People",
+                Schema = "dbo",
+                Columns = ["FirstName", "LastName"]
+            });
+
+        AssertSql(
+            """
+DROP INDEX [IX_People_Name] ON [dbo].[People];
+GO
+
+CREATE INDEX [IX_People_OtherName] ON [dbo].[People] ([FirstName], [LastName]);
+""");
+    }
