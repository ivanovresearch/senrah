+        // Normalize List<T>.Exists(predicate) to Enumerable.Any(source, predicate)
+        // List<T>.Exists takes a Predicate<T> which is structurally identical to Func<T, bool>
+        if (methodCallExpression is
+            {
+                Method:
+                {
+                    Name: nameof(List<object>.Exists),
+                    IsStatic: false,
+                    DeclaringType: { IsGenericType: true } existsDeclaringType
+                },
+                Object: { } existsSource,
+                Arguments: [var existsPredicate]
+            }
+            && existsDeclaringType.GetGenericTypeDefinition() == typeof(List<>))
+        {
+            var elementType = existsSource.Type.GetSequenceType();
+            // Convert Predicate<T> lambda to Func<T, bool> lambda if needed
+            var predicate = existsPredicate is LambdaExpression lambdaExpression
+                ? Expression.Lambda(typeof(Func<,>).MakeGenericType(elementType, typeof(bool)), lambdaExpression.Body, lambdaExpression.Parameters)
+                : existsPredicate;
+
+            return VisitMethodCall(
+                Expression.Call(
+                    EnumerableMethods.AnyWithPredicate.MakeGenericMethod(elementType),
+                    existsSource,
+                    predicate));
+        }
+
