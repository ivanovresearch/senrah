+        SqlExpression TranslateSign(SqlExpression arg)
+        {
+            var typeMapping = ExpressionExtensions.InferTypeMapping(arg);
+            SqlExpression result = sqlExpressionFactory.Function(
+                "SIGN",
+                [sqlExpressionFactory.ApplyTypeMapping(arg, typeMapping)],
+                nullable: true,
+                argumentsPropagateNullability: Statics.TrueArrays[1],
+                arg.Type,
+                typeMapping);
+
+            // T-SQL SIGN returns the same type as its argument, but Math.Sign always returns int.
+            // For non-integer argument types (decimal, double, float, long, sbyte, short), we must
+            // CAST the result to int to match the expected C# return type.
+            if (arg.Type != typeof(int))
+            {
+                result = sqlExpressionFactory.Convert(result, typeof(int));
+            }
+
+            return result;
+        }
