+    private static bool TryGetValueFromDictionary(
+        IProperty property,
+        IDictionary<string, object?> values,
+        out object? value)
+    {
+        // Build the path-qualified key for properties declared on complex types.
+        // For example, a property "CodeExtended" on complex type "TaxInfoExtended" has the
+        // path-qualified key "TaxInfoExtended.CodeExtended", which distinguishes it from the same
+        // property on a second complex property of the same type (e.g. "TaxInfoExtended2.CodeExtended").
+        if (property.DeclaringType is IComplexType)
+        {
+            // Try path-qualified key first (e.g. "TaxInfoExtended.CodeExtended").
+            var pathKey = GetPropertyPath(property);
+            if (values.TryGetValue(pathKey, out value))
+            {
+                return true;
+            }
+
+            // Try to extract the value from a complex CLR object stored in the dictionary under the
+            // root complex property name (e.g. "TaxInfoExtended" -> CLR object).
+            if (TryGetValueFromComplexObject(property, values, out value))
+            {
+                return true;
+            }
+
+            // Fall back to leaf name only for backward compatibility with callers that use simple
+            // (non-ambiguous) flat keys.
+            return values.TryGetValue(property.Name, out value);
+        }
+
+        return values.TryGetValue(property.Name, out value);
+    }
+
+    private static string GetPropertyPath(IProperty property)
+    {
+        var name = property.Name;
+        var declaringType = property.DeclaringType;
+        while (declaringType is IComplexType complexType)
+        {
+            name = complexType.ComplexProperty.Name + "." + name;
+            declaringType = complexType.ComplexProperty.DeclaringType;
+        }
+
+        return name;
+    }
+
+    private static bool TryGetValueFromComplexObject(
+        IProperty property,
+        IDictionary<string, object?> values,
+        out object? value)
+    {
+        // Walk up the complex type chain to collect the path from root to leaf.
+        var chain = new List<IComplexProperty>();
+        var declaringType = property.DeclaringType;
+        while (declaringType is IComplexType complexType)
+        {
+            chain.Insert(0, complexType.ComplexProperty);
+            declaringType = complexType.ComplexProperty.DeclaringType;
+        }
+
+        // Look up the root complex property object in the values dictionary.
+        // If the root complex property is a shadow property, it has no CLR backing and cannot be used.
+        if (chain[0].IsShadowProperty()
+            || !values.TryGetValue(chain[0].Name, out var complexObject)
+            || complexObject == null)
+        {
+            value = null;
+            return false;
+        }
+
+        // Walk down the chain through any nested complex types.
+        for (var i = 1; i < chain.Count; i++)
+        {
+            if (chain[i].IsShadowProperty())
+            {
+                value = null;
+                return false;
+            }
+
+            complexObject = chain[i].GetGetter().GetClrValue(complexObject);
+            if (complexObject == null)
+            {
+                value = null;
+                return false;
+            }
+        }
+
+        // Read the leaf scalar property from the innermost complex type object.
+        // Shadow properties have no CLR backing, so they cannot be extracted from a CLR object.
+        if (property.IsShadowProperty())
+        {
+            value = null;
+            return false;
+        }
+
+        value = property.GetGetter().GetClrValue(complexObject);
+        return true;
+    }
+
