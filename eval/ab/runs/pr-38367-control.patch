+    [Fact]
+    public void CreateEntry_with_path_qualified_keys_distinguishes_multiple_complex_properties_of_same_type()
+    {
+        var model = CreateModelWithDuplicateComplexType();
+        var entityType = model.FindEntityType(typeof(TaxInfo))!;
+
+        var serviceProvider = InMemoryTestHelpers.Instance.CreateContextServices(model);
+        var stateManager = serviceProvider.GetRequiredService<IStateManager>();
+
+        // Callers must use path-qualified keys (e.g. "TaxInfoExtended.CodeExtended") to distinguish
+        // between properties from multiple complex properties of the same ComplexType.
+        var values = new Dictionary<string, object?>
+        {
+            { "TaxInfoId", 1 },
+            { "Code", 'A' },
+            { "Percentage", 12.5m },
+            { "TaxInfoExtended.CodeExtended", 10 },
+            { "TaxInfoExtended.PercentageExtended", 0.1m },
+            { "TaxInfoExtended2.CodeExtended", 20 },
+            { "TaxInfoExtended2.PercentageExtended", 0.2m },
+            { "ExtraValue", 99 },
+        };
+
+        var entry = stateManager.CreateEntry(values, entityType);
+
+        var taxInfoExtended = entityType.FindComplexProperty(nameof(TaxInfo.TaxInfoExtended))!;
+        var taxInfoExtended2 = entityType.FindComplexProperty(nameof(TaxInfo.TaxInfoExtended2))!;
+        var codeExtended1 = taxInfoExtended.ComplexType.FindProperty(nameof(TaxInfoExtended.CodeExtended))!;
+        var codeExtended2 = taxInfoExtended2.ComplexType.FindProperty(nameof(TaxInfoExtended.CodeExtended))!;
+        var percentageExtended1 = taxInfoExtended.ComplexType.FindProperty(nameof(TaxInfoExtended.PercentageExtended))!;
+        var percentageExtended2 = taxInfoExtended2.ComplexType.FindProperty(nameof(TaxInfoExtended.PercentageExtended))!;
+
+        Assert.Equal(10, entry.GetCurrentValue(codeExtended1));
+        Assert.Equal(0.1m, entry.GetCurrentValue(percentageExtended1));
+        Assert.Equal(20, entry.GetCurrentValue(codeExtended2));
+        Assert.Equal(0.2m, entry.GetCurrentValue(percentageExtended2));
+    }
+
+    [Fact]
+    public void CreateEntry_with_complex_clr_objects_in_dict_populates_complex_type_values()
+    {
+        var model = CreateModelWithDuplicateComplexType();
+        var entityType = model.FindEntityType(typeof(TaxInfo))!;
+
+        var serviceProvider = InMemoryTestHelpers.Instance.CreateContextServices(model);
+        var stateManager = serviceProvider.GetRequiredService<IStateManager>();
+
+        // Callers may also pass CLR objects for complex properties (the format produced by GetSeedData).
+        var ext1 = new TaxInfoExtended { CodeExtended = 10, PercentageExtended = 0.1m };
+        var ext2 = new TaxInfoExtended { CodeExtended = 20, PercentageExtended = 0.2m };
+        var values = new Dictionary<string, object?>
+        {
+            { "TaxInfoId", 1 },
+            { "Code", 'A' },
+            { "Percentage", 12.5m },
+            { "TaxInfoExtended", ext1 },
+            { "TaxInfoExtended2", ext2 },
+            { "ExtraValue", 99 },
+        };
+
+        var entry = stateManager.CreateEntry(values, entityType);
+
+        var taxInfoExtended = entityType.FindComplexProperty(nameof(TaxInfo.TaxInfoExtended))!;
+        var taxInfoExtended2 = entityType.FindComplexProperty(nameof(TaxInfo.TaxInfoExtended2))!;
+        var codeExtended1 = taxInfoExtended.ComplexType.FindProperty(nameof(TaxInfoExtended.CodeExtended))!;
+        var codeExtended2 = taxInfoExtended2.ComplexType.FindProperty(nameof(TaxInfoExtended.CodeExtended))!;
+        var percentageExtended1 = taxInfoExtended.ComplexType.FindProperty(nameof(TaxInfoExtended.PercentageExtended))!;
+        var percentageExtended2 = taxInfoExtended2.ComplexType.FindProperty(nameof(TaxInfoExtended.PercentageExtended))!;
+
+        Assert.Equal(10, entry.GetCurrentValue(codeExtended1));
+        Assert.Equal(0.1m, entry.GetCurrentValue(percentageExtended1));
+        Assert.Equal(20, entry.GetCurrentValue(codeExtended2));
+        Assert.Equal(0.2m, entry.GetCurrentValue(percentageExtended2));
+    }
+
+    private static IModel CreateModelWithDuplicateComplexType()
+    {
+        var modelBuilder = InMemoryTestHelpers.Instance.CreateConventionBuilder();
+
+        modelBuilder.Entity<TaxInfo>(eb =>
+        {
+            eb.ComplexProperty(e => e.TaxInfoExtended);
+            eb.ComplexProperty(e => e.TaxInfoExtended2);
+        });
+
+        return modelBuilder.FinalizeModel();
+    }
+
+    private class TaxInfo
+    {
+        public int TaxInfoId { get; set; }
+        public char Code { get; set; }
+        public decimal Percentage { get; set; }
+        public TaxInfoExtended TaxInfoExtended { get; set; } = new();
+        public TaxInfoExtended TaxInfoExtended2 { get; set; } = new();
+        public int ExtraValue { get; set; }
+    }
+
+    private class TaxInfoExtended
+    {
+        public int CodeExtended { get; set; }
+        public decimal PercentageExtended { get; set; }
+    }
