+    /// </summary>
+    protected virtual Expression VisitSqliteAggregateFunction(SqliteAggregateFunctionExpression aggregateFunctionExpression)
+    {
+        // SQLite 3.44.0+ aggregate ORDER BY syntax: func(arg [, ...] ORDER BY col [, ...])
+        Sql.Append(aggregateFunctionExpression.Name).Append("(");
+        GenerateList(aggregateFunctionExpression.Arguments, e => Visit(e));
+
+        if (aggregateFunctionExpression.Orderings.Count > 0)
+        {
+            Sql.Append(" ORDER BY ");
+            GenerateList(aggregateFunctionExpression.Orderings, e => Visit(e));
+        }
+
+        Sql.Append(")");
+
+        return aggregateFunctionExpression;
+    }
+
