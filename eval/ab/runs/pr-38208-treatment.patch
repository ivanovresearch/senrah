+    private static bool AnalyzeStringMethodInvocation(IInvocationOperation invocation)
+    {
+        var method = invocation.TargetMethod;
+
+        if (method.ContainingType.SpecialType != SpecialType.System_String)
+        {
+            return false;
+        }
+
+        if (method.Name is not ("Format" or "Concat"))
+        {
+            return false;
+        }
+
+        // Only report if at least one argument is non-constant
+        foreach (var argument in invocation.Arguments)
+        {
+            if (!argument.Value.ConstantValue.HasValue)
+            {
+                return true;
+            }
+        }
+
+        return false;
+    }
+
