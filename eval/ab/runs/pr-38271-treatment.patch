             options.Add("FILLFACTOR = " + fillFactor);
@@ -3543,6 +3548,30 @@ static bool AnnotationsAreTheSame(ColumnOperation column, ColumnOperation oldCol
                 temporalInformation.Value.SuppressTransaction);
         }
 
+        // Collapse DropIndexOperation + CreateIndexOperation pairs for the same index into a single
+        // CREATE INDEX ... WITH (DROP_EXISTING = ON), which is more efficient and allows queries to
+        // continue using the old index while the new one is being built.
+        for (var i = operations.Count - 1; i >= 1; i--)
+        {
+            if (operations[i] is CreateIndexOperation createOp
+                && operations[i - 1] is DropIndexOperation dropOp
+                && string.Equals(dropOp.Name, createOp.Name, StringComparison.OrdinalIgnoreCase)
+                && string.Equals(dropOp.Table, createOp.Table, StringComparison.OrdinalIgnoreCase)
+                && string.Equals(dropOp.Schema, createOp.Schema, StringComparison.OrdinalIgnoreCase)
+                // Full-text indexes use a different DDL syntax that does not support DROP_EXISTING.
+                && createOp[SqlServerAnnotationNames.FullTextIndex] is null
+                // Vector indexes use CREATE VECTOR INDEX syntax that does not support DROP_EXISTING.
+                && createOp[SqlServerAnnotationNames.VectorIndexMetric] is null
+                // JSON indexes use CREATE JSON INDEX syntax that does not support DROP_EXISTING.
+                && createOp[RelationalAnnotationNames.JsonIndex] is null
+                // Memory-optimized tables use ALTER TABLE ... ADD INDEX and do not support DROP_EXISTING.
+                && !IsMemoryOptimized(createOp, model, createOp.Schema, createOp.Table))
+            {
+                createOp[SqlServerAnnotationNames.DropExisting] = true;
+                operations.RemoveAt(i - 1);
+            }
+        }
+
         return operations;
 
