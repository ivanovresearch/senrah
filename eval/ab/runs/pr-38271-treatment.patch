@@ -2164,6 +2164,11 @@ protected override void IndexOptions(MigrationOperation operation, IModel? model
 
         var options = new List<string>();
 
+        if (operation[SqlServerAnnotationNames.DropExisting] is true)
+        {
+            options.Add("DROP_EXISTING = ON");
+        }
+
         if (operation[SqlServerAnnotationNames.FillFactor] is int fillFactor)
