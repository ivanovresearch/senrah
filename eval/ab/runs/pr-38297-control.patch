@@ -419,6 +419,37 @@ private ShapedQueryExpression CreateShapedQueryExpression(SelectExpression selec
             return source.Update(select, new ProjectionBindingExpression(select, new ProjectionMember(), typeof(int)));
         }
 
+        // Cosmos does not support uncorrelated subqueries (EXISTS can only reference an array property on the current document).
+        // For top-level Any(), translate to LIMIT 1 with a constant true projection instead of EXISTS.
+        // If at least one document matches, the query returns a single true; if no documents match, no rows are returned and
+        // SingleOrDefault produces the default value (false).
+        if (!_subquery)
+        {
+            var selectExpression = (SelectExpression)source.QueryExpression;
+
+            // Clear orderings only when there is no OFFSET/LIMIT already; ordering is irrelevant for an existence check.
+            if (selectExpression.Limit == null && selectExpression.Offset == null)
+            {
+                selectExpression.ClearOrdering();
+            }
+
+            if (!TryApplyLimit(selectExpression, TranslateExpression(Expression.Constant(1))!))
+            {
+                return null;
+            }
+
+            var trueValue = _sqlExpressionFactory.ApplyDefaultTypeMapping(_sqlExpressionFactory.Constant(true));
+            selectExpression.ReplaceProjectionMapping(
+                new Dictionary<ProjectionMember, Expression> { { new ProjectionMember(), trueValue } });
+
+            return source
+                .UpdateShaperExpression(
+                    Expression.Convert(
+                        new ProjectionBindingExpression(selectExpression, new ProjectionMember(), typeof(bool?)),
+                        typeof(bool)))
+                .UpdateResultCardinality(ResultCardinality.SingleOrDefault);
+        }
+
         var subquery = (SelectExpression)source.QueryExpression;
         subquery.ClearProjection();
         subquery.ApplyProjection();
@@ -429,11 +460,11 @@ private ShapedQueryExpression CreateShapedQueryExpression(SelectExpression selec
         }
 
         var translation = _sqlExpressionFactory.Exists(subquery);
-        var selectExpression = new SelectExpression(translation);
+        var existsSelectExpression = new SelectExpression(translation);
 
         return source.Update(
-            selectExpression,
-            Expression.Convert(new ProjectionBindingExpression(selectExpression, new ProjectionMember(), typeof(bool?)), typeof(bool)));
+            existsSelectExpression,
+            Expression.Convert(new ProjectionBindingExpression(existsSelectExpression, new ProjectionMember(), typeof(bool?)), typeof(bool)));
     }
 
