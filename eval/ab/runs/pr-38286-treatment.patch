+++ "b/C:\\Work\\efcore-ab\\runs\\pr-38286-treatment/src/EFCore.Relational/Query/RelationalTypeMappingPostprocessor.cs"
@@ -161,7 +161,22 @@ protected virtual ValuesExpression ApplyTypeMappingsOnValuesExpression(ValuesExp
                         // types are properly typed. See #30605 for removing that when not needed.
                         if (i == 0 && j > 0 && value is not ColumnExpression)
                         {
-                            value = new SqlUnaryExpression(ExpressionType.Convert, value, value.Type, value.TypeMapping);
+                            // If no type mapping was inferred from context (e.g. the values are never compared to a typed column, as in
+                            // SelectMany with an inline array), fall back to the default mapping for the CLR type so that the CAST can
+                            // be generated correctly. See #38286.
+                            if (value.TypeMapping is null)
+                            {
+                                value = _sqlExpressionFactory.ApplyTypeMapping(
+                                    value,
+                                    RelationalDependencies.TypeMappingSource.FindMapping(value.Type, QueryCompilationContext.Model));
+                            }
+
+                            // Only wrap in a CAST if we have a type mapping; if none could be found at all, skip the conversion to avoid
+                            // a NullReferenceException in the SQL generator.
+                            if (value.TypeMapping is not null)
+                            {
+                                value = new SqlUnaryExpression(ExpressionType.Convert, value, value.Type, value.TypeMapping);
+                            }
                         }
 
                         newValues[j] = value;
