+        // Normalize List<T>.Exists(predicate) to Enumerable.Any<T>(source, predicate)
+        if (methodCallExpression is
+            {
+                Method:
+                {
+                    Name: nameof(List<object>.Exists),
+                    IsStatic: false,
+                    DeclaringType: { IsGenericType: true } existsDeclaringType
+                },
+                Object: { } existsSource,
+                Arguments: [var existsPredicate]
+            }
+            && existsDeclaringType.GetGenericTypeDefinition() == typeof(List<>))
+        {
+            var elementType = existsSource.Type.GetSequenceType();
+            // Convert Predicate<T> lambda to Func<T, bool> lambda (same body/params, different delegate type)
+            var predicateLambda = existsPredicate is LambdaExpression lambda
+                ? Expression.Lambda(typeof(Func<,>).MakeGenericType(elementType, typeof(bool)), lambda.Body, lambda.Parameters)
+                : existsPredicate;
+
+            return VisitMethodCall(
+                Expression.Call(
+                    EnumerableMethods.AnyWithPredicate.MakeGenericMethod(elementType),
+                    existsSource,
+                    predicateLambda));
+        }
