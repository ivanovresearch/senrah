+    /// <summary>
+    ///     Gets the key used when looking up this property in an <see cref="IDictionary{TKey, TValue}" /> of property values
+    ///     (e.g. as passed to <see cref="IUpdateEntry.CreateEntry" />). For properties directly on an entity type this is
+    ///     the property <see cref="IReadOnlyPropertyBase.Name" />. For properties declared on a complex type this is the
+    ///     dot-delimited path of complex property names followed by the property name, e.g.
+    ///     <c>TaxInfoExtended.CodeExtended</c> or <c>TaxInfoExtended2.CodeExtended</c>. This allows callers to
+    ///     distinguish between properties with the same name belonging to different complex-property instances of the
+    ///     same complex type.
+    /// </summary>
+    /// <remarks>
+    ///     This is an internal API that supports the Entity Framework Core infrastructure and not subject to
+    ///     the same compatibility standards as public APIs. It may be changed or removed without notice in
+    ///     any release. You should only use it directly in your code with extreme caution and knowing that
+    ///     doing so can result in application failures when updating to a new Entity Framework Core release.
+    /// </remarks>
+    public static string GetFlattenedPropertyKey(this IReadOnlyPropertyBase propertyBase)
+    {
+        if (propertyBase.DeclaringType is not IReadOnlyComplexType)
+        {
+            return propertyBase.Name;
+        }
+
+        // Walk up the chain of complex property declarations to build the path.
+        var segments = new Stack<string>();
+        segments.Push(propertyBase.Name);
+        var declaringType = propertyBase.DeclaringType;
+        while (declaringType is IReadOnlyComplexType complexType)
+        {
+            segments.Push(complexType.ComplexProperty.Name);
+            declaringType = complexType.ComplexProperty.DeclaringType;
+        }
+
+        return string.Join(".", segments);
+    }
+
