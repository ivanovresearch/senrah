+
+                // Flatten non-collection complex properties into path-keyed scalar entries so that
+                // InternalEntityEntry can look them up unambiguously even when multiple complex
+                // properties of the same CLR type share identically-named sub-properties.
+                foreach (var complexProperty in GetFlattenedComplexProperties())
+                {
+                    if (complexProperty.IsCollection || complexProperty.IsShadowProperty())
+                    {
+                        continue;
+                    }
+
+                    foreach (var flatProperty in complexProperty.ComplexType.GetDeclaredProperties())
+                    {
+                        if (flatProperty.IsShadowProperty())
+                        {
+                            continue;
+                        }
+
+                        var key = flatProperty.GetFlattenedPropertyKey();
+                        if (seed.ContainsKey(key))
+                        {
+                            continue;
+                        }
+
+                        ValueConverter? valueConverter = null;
+                        if (providerValues
+                            && !valueConverters.TryGetValue(key, out valueConverter))
+                        {
+                            valueConverter = flatProperty.GetTypeMapping().Converter;
+                            valueConverters[key] = valueConverter;
+                        }
+
+                        // Navigate to the complex object that owns this property.
+                        // Walk up the complex property chain to find the containing object.
+                        var chain = new List<IComplexProperty>();
+                        var declaringType = (IReadOnlyTypeBase)flatProperty.DeclaringType;
+                        while (declaringType is IReadOnlyComplexType ct)
+                        {
+                            chain.Insert(0, ct.ComplexProperty);
+                            declaringType = ct.ComplexProperty.DeclaringType;
+                        }
+
+                        object? complexObj = rawSeed;
+                        foreach (var cp in chain)
+                        {
+                            if (complexObj == null)
+                            {
+                                break;
+                            }
+
+                            var cpMemberInfo = cp.GetMemberInfo(forMaterialization: false, forSet: false);
+                            complexObj = cpMemberInfo switch
+                            {
+                                PropertyInfo pi => pi.GetValue(complexObj),
+                                FieldInfo fi => fi.GetValue(complexObj),
+                                _ => null
+                            };
+                        }
+
+                        if (complexObj == null)
+                        {
+                            continue;
+                        }
+
+                        var leafMemberInfo = flatProperty.GetMemberInfo(forMaterialization: false, forSet: false);
+                        var value = leafMemberInfo switch
+                        {
+                            PropertyInfo pi => pi.GetValue(complexObj),
+                            FieldInfo fi => fi.GetValue(complexObj),
+                            _ => null
+                        };
+
